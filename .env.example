# ============================================================
# YouTube Automation Pro — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.

# --- AI Script Generation ---
GEMINI_API_KEY=
SCRIPT_PROVIDER=local

# --- Text-to-Speech ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
TTS_PRIMARY=edge

# --- B-Roll Video Sources ---
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- Trend Detection ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=youtube-automation-pro/1.0

# --- YouTube Upload ---
YOUTUBE_DATA_API_KEY=
YOUTUBE_CLIENT_SECRETS_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=.youtube_token.json

# --- Thumbnail Generation ---
IDEOGRAM_API_KEY=

# --- System Config ---
DEFAULT_LANGUAGE=es
PIPELINE_MAX_TOPICS=5
PIPELINE_RETRIES=3
API_TOKEN=changeme-secure-token-here

# --- Operational Limits & Delays ---
# Daily API quotas (soft limits, warn if exceeded)
QUOTA_YOUTUBE_DATA_API_DAILY=250
QUOTA_PEXELS_DAILY=500
QUOTA_PIXABAY_DAILY=500
QUOTA_ELEVENLABS_DAILY=400
QUOTA_REDDIT_DAILY=1000
QUOTA_GOOGLE_TRENDS_DAILY=1000

# Pipeline execution
PIPELINE_CHANNEL_DELAY_SECONDS=90      # Delay between channel pipeline runs (avoid API saturation)
PIPELINE_AUTO_PAUSE_AFTER_ERRORS=3     # Auto-pause channel after N consecutive pipeline errors
PIPELINE_STRICT_MODE=false              # If true, fail on any API error; if false, use fallbacks

# Video quality & encoding
VIDEO_MIN_DURATION_SECONDS=240          # Minimum video length (4 minutes)
VIDEO_MAX_DURATION_SECONDS=1080         # Maximum video length (18 minutes)
VIDEO_BITRATE_MBPS=8                    # MP4 encoding bitrate (8 Mbps recommended for quality)
VIDEO_TARGET_RESOLUTION=1080p           # Target resolution (1080p or 720p)

# B-Roll fetching
BROLL_MIN_CLIPS=12                      # Minimum footage clips per video
BROLL_MAX_CLIPS=28                      # Maximum footage clips per video
BROLL_TIMEOUT_SECONDS=300               # Max time to fetch B-roll (5 min)

# Voice/Audio
AUDIO_CHUNK_SIZE=1000                   # Characters per TTS chunk (for long scripts)
AUDIO_BITRATE_KBPS=192                  # Audio bitrate in AAC encoding
AUDIO_SAMPLE_RATE=44100                 # Sample rate (Hz)
ALLOW_SILENT_FALLBACK=false             # Fail if audio is silent; set true to allow silent videos

# Script generation
SCRIPT_MAX_RETRIES=2                    # Retries if script generation fails
SCRIPT_HIDE_ERRORS=true                 # Hide internal error details in logs

# Thumbnail generation
THUMBNAIL_MAX_RETRIES=2                 # Retries if thumbnail fails
THUMBNAIL_FALLBACK_COLOR=#FF6B35        # Fallback color if all providers fail

# YouTube Upload
YOUTUBE_UPLOAD_TIMEOUT_SECONDS=1800     # Upload timeout (30 min for large files)
YOUTUBE_RETRY_BACKOFF_SECONDS=60        # Backoff for API rate limiting

# Logging
LOG_LEVEL=INFO                          # DEBUG, INFO, WARNING, ERROR
LOG_FILE_RETENTION_DAYS=30              # Keep logs for N days
ENABLE_DETAILED_PHASE_LOGS=true         # Log each pipeline phase in detail

# Multi-agent (Pixel Agents)
MAX_CONCURRENT_AGENTS=10                # Max agents running simultaneously
AGENT_SESSION_TIMEOUT_MINUTES=120       # Timeout per agent session (2 hours)
AGENT_MEMORY_BUFFER_MB=256              # Memory buffer per agent process

# Monitoring & Alerts
ENABLE_MONITORING=false                 # Enable internal monitoring (log to analytics)
WEBHOOK_ERROR_ALERTS=                   # Optional: POST errors to webhook URL
WEBHOOK_SUCCESS_REPORTS=                # Optional: POST success reports to webhook URL
